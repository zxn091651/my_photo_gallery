{
  "name": "my-photo-gallery",
  "version": "0.1.0",
  "private": true,
  "description": "A local media gateway plus a static gallery frontend for browsing a removable drive backup folder.",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "startup:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-startup-task.ps1",
    "startup:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-startup-task.ps1"
  },
  "engines": {
    "node": ">=20"
  }
}
