{
  "name": "my-photo-gallery",
  "version": "0.1.0",
  "private": true,
  "description": "A local media gateway plus a static gallery frontend for browsing a removable drive backup folder.",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "backend:start": "powershell -NoProfile -WindowStyle Hidden -ExecutionPolicy Bypass -File scripts/start-gallery.ps1",
    "backend:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-gallery.ps1",
    "launchers:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-launchers.ps1",
    "startup:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-startup-task.ps1",
    "startup:uninstall": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-startup-task.ps1"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "ffmpeg-static": "^5.3.0",
    "sharp": "^0.35.3"
  }
}
